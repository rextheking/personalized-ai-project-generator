# Personalized AI Project Generator — infra shortcuts.
#
# Uses the venv's Python directly so you don't have to activate it.
# Sets JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION so Node 25+ users don't see
# the untested-version banner.

STACK   := AiProjectGeneratorStack
APP     := .venv/bin/python3 app.py
CDK     := JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 cdk
REGION  ?= us-east-1

.PHONY: help install bootstrap synth diff deploy outputs upload-web invalidate destroy clean

help:
	@echo "Personalized AI Project Generator — infra targets"
	@echo ""
	@echo "  make install      Create venv and install CDK deps"
	@echo "  make bootstrap    Bootstrap the account/region for CDK (first time only)"
	@echo "  make synth        Synthesize the CloudFormation template"
	@echo "  make diff         Show pending changes vs. deployed stack"
	@echo "  make deploy       Deploy the stack"
	@echo "  make outputs      Print stack outputs (API URL, website URL, etc.)"
	@echo "  make upload-web   Write web/config.js, upload frontend, invalidate cache"
	@echo "  make invalidate   Invalidate the CloudFront distribution cache"
	@echo "  make destroy      Tear everything down"
	@echo "  make clean        Remove cdk.out and caches"

install:
	python3.12 -m venv .venv
	.venv/bin/pip install --upgrade pip --index-url https://pypi.org/simple/
	.venv/bin/pip install -r requirements.txt --index-url https://pypi.org/simple/

bootstrap:
	$(CDK) bootstrap --app "$(APP)"

synth:
	$(CDK) synth --app "$(APP)" --quiet

diff:
	$(CDK) diff --app "$(APP)"

deploy:
	$(CDK) deploy --app "$(APP)" --require-approval never

outputs:
	@aws cloudformation describe-stacks --stack-name $(STACK) --region $(REGION) \
		--query 'Stacks[0].Outputs' --output table

# Reads stack outputs, writes web/config.js with the live API endpoint, uploads
# the frontend to S3 and invalidates the CloudFront cache.
upload-web:
	@API_URL=$$(aws cloudformation describe-stacks --stack-name $(STACK) --region $(REGION) \
		--query 'Stacks[0].Outputs[?OutputKey==`ApiEndpoint`].OutputValue' --output text); \
	BUCKET=$$(aws cloudformation describe-stacks --stack-name $(STACK) --region $(REGION) \
		--query 'Stacks[0].Outputs[?OutputKey==`WebBucketName`].OutputValue' --output text); \
	DIST_ID=$$(aws cloudformation describe-stacks --stack-name $(STACK) --region $(REGION) \
		--query 'Stacks[0].Outputs[?OutputKey==`DistributionId`].OutputValue' --output text); \
	echo "// Generated by make upload-web. Do not edit by hand." > ../frontend/config.js; \
	echo "window.API_ENDPOINT = \"$$API_URL\";" >> ../frontend/config.js; \
	aws s3 sync ../frontend/ s3://$$BUCKET/ --region $(REGION) --delete; \
	aws cloudfront create-invalidation --distribution-id $$DIST_ID --paths "/*" --region $(REGION) >/dev/null; \
	echo "Frontend uploaded and cache invalidated."

invalidate:
	@DIST_ID=$$(aws cloudformation describe-stacks --stack-name $(STACK) --region $(REGION) \
		--query 'Stacks[0].Outputs[?OutputKey==`DistributionId`].OutputValue' --output text); \
	aws cloudfront create-invalidation --distribution-id $$DIST_ID --paths "/*" --region $(REGION)

destroy:
	$(CDK) destroy --app "$(APP)" --force

clean:
	rm -rf cdk.out .pytest_cache
